# ── CoinMarketCap ──────────────────────────────────────────────────────────────
# Required. Get a free key at https://coinmarketcap.com/api/
CMC_API_KEY=your_coinmarketcap_api_key

# Optional: override the CMC Agent Hub MCP endpoint (defaults to the official URL)
# CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp

# Optional: use a separate key for MCP calls (falls back to CMC_API_KEY if unset)
# CMC_MCP_API_KEY=your_mcp_api_key

# ── Trading mode ───────────────────────────────────────────────────────────────
# testnet  = real signals, simulated trades (default, safe for testing)
# mainnet  = real signals, real on-chain swaps via TWAK CLI
TRADING_MODE=testnet

# ── Capital & risk parameters ──────────────────────────────────────────────────
INITIAL_CAPITAL_USD=100
MAX_POSITION_PCT=0.10       # max % of portfolio per position (0.10 = 10%)
STOP_LOSS_PCT=0.08          # close position if it drops this much from entry
MAX_DRAWDOWN_PCT=0.20       # stop opening new positions beyond this drawdown

# ── Execution ──────────────────────────────────────────────────────────────────
SLIPPAGE=1.0                # swap slippage tolerance % passed to TWAK CLI
SCAN_INTERVAL_MINUTES=15    # how often to run a full cycle (15 = every 15 min)
